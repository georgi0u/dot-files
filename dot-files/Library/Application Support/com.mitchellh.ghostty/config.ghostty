theme=dark:niji,light:Coffee Theme
copy-on-select=clipboard
clipboard-read=allow
clipboard-write=allow
confirm-close-surface=false
font-family = "Monaspace Neon Var"
# ss01: != and ===
font-feature = "ss01"
# ss02: <= and >=
font-feature = "ss02"
# ss03: -> and ~>
font-feature = "ss03"
# ss04: <> and </>
font-feature = "ss04"
# liga: //, ..., ||
font-feature = "liga"